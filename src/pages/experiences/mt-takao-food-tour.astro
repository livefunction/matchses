---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HostProfile from '../../components/experience/HostProfile.astro';

const experience = {
  title: 'Mt. Takao Food Tour',
  subtitle: 'Explore the ancient trails of Mt. Takao with a local guide. Taste traditional soba, tea, and local snacks along the way.',
  price: 89,
  duration: '4 hours',
  rating: 4.9,
  reviews: 127,
  category: 'Food & Drink',
  image: 'linear-gradient(135deg, #84CC16 0%, #65A30D 100%)',
  highlights: ['Local Guide', 'Food Included', 'Mountain Trail', 'English Speaking'],
  
  includes: [
    'English-speaking local guide',
    '3 traditional food stops',
    'Tastings at each location',
    'Mountain trail hiking',
    'Photo opportunities',
    'Small group (max 8 people)'
  ],
  
  schedule: [
    { time: '09:30', activity: 'Meet at Takao Station' },
    { time: '10:00', activity: 'Visit historic soba restaurant' },
    { time: '11:30', activity: 'Tea ceremony experience' },
    { time: '12:30', activity: 'Local sweet shop' },
    { time: '13:30', activity: 'Tour ends at Takao Station' }
  ],
  
  meetingPoint: 'JR Takao Station (Keio Line), West Exit',
  whatToBring: ['Comfortable walking shoes', 'Water bottle', 'Camera', 'Light jacket'],
  cancellation: 'Free cancellation up to 24 hours before the experience'
};

const host = {
  name: 'Takeshi Sato',
  role: 'Food Expert',
  location: 'Takao Area',
  bio: 'Born in Hachioji, Takeshi spent 15 years as a sushi chef in Ginza before returning to his hometown. Now he leads food tours that showcase the soul of Tama cuisine—from mountain soba to hidden izakaya.',
  quote: 'I want visitors to taste what I grew up eating. Real food, made by real people, with real stories.',
  yearsExperience: 'Leading tours since 2019',
  specialties: ['Sushi', 'Soba', 'Izakaya Culture', 'Local History'],
  imageGradient: 'linear-gradient(135deg, #84CC16 0%, #65A30D 100%)',
  rating: 4.9,
  reviewCount: 127,
  hostHref: '/hosts'
};
---

<BaseLayout 
  title="Mt. Takao Food Tour - MATCHS"
  description="Explore the ancient trails of Mt. Takao with a local guide. Taste traditional soba, tea, and local snacks along the way. Book now!"
>
  <section class="experience-hero">
    <div class="hero-image" style={`background: ${experience.image}`}>
      <div class="hero-overlay"></div>
    </div>
    <div class="container">
      <div class="hero-content">
        <a href="/experiences" class="back-link">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M15 10H5M5 10L10 5M5 10L10 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          All Experiences
        </a>
        <span class="category-tag">{experience.category}</span>
        <h1 class="experience-title">{experience.title}</h1>
        <p class="experience-subtitle">{experience.subtitle}</p>
        
        <div class="experience-meta">
          <div class="meta-item">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="2"/>
              <path d="M10 6V10L13 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <span>{experience.duration}</span>
          </div>
          <div class="meta-item">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M10 1L12.163 5.279L17 5.635L13.5 8.794L14.326 13.636L10 11.279L5.674 13.636L6.5 8.794L3 5.635L7.837 5.279L10 1Z" fill="#F59E0B"/>
            </svg>
            <span>{experience.rating} ({experience.reviews} reviews)</span>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <section class="experience-content">
    <div class="container">
      <div class="content-grid">
        <div class="main-content">
          <HostProfile {...host} />
          
          <div class="section-block">
            <h2>Tour Highlights</h2>
            <ul class="highlights-list">
              {experience.highlights.map(h => (
                <li>
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <path d="M16.667 5L7.5 14.167L3.333 10" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {h}
                </li>
              ))}
            </ul>
          </div>
          
          <div class="section-block">
            <h2>What's Included</h2>
            <ul class="includes-list">
              {experience.includes.map(item => (
                <li>
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <path d="M16.667 5L7.5 14.167L3.333 10" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          
          <div class="section-block">
            <h2>Tour Schedule</h2>
            <div class="schedule-timeline">
              {experience.schedule.map(item => (
                <div class="schedule-item">
                  <span class="schedule-time">{item.time}</span>
                  <span class="schedule-activity">{item.activity}</span>
                </div>
              ))}
            </div>
          </div>
          
          <div class="section-block">
            <h2>Important Information</h2>
            <div class="info-cards">
              <div class="info-card">
                <h3>Meeting Point</h3>
                <p>{experience.meetingPoint}</p>
              </div>
              <div class="info-card">
                <h3>What to Bring</h3>
                <ul>
                  {experience.whatToBring.map(item => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
              <div class="info-card">
                <h3>Cancellation</h3>
                <p>{experience.cancellation}</p>
              </div>
            </div>
          </div>
        </div>
        
        <aside class="booking-sidebar">
          <div class="booking-card">
            <div class="price-display">
              <span class="price-amount">${experience.price}</span>
              <span class="price-label">/ person</span>
            </div>
            
            <form class="booking-form">
              <div class="form-group">
                <label>Select Date</label>
                <input type="date" class="form-input" required />
              </div>
              <div class="form-group">
                <label>Number of Guests</label>
                <select class="form-select" required>
                  <option value="">Select guests</option>
                  <option value="1">1 Guest</option>
                  <option value="2">2 Guests</option>
                  <option value="3">3 Guests</option>
                  <option value="4">4 Guests</option>
                  <option value="5">5+ Guests</option>
                </select>
              </div>
              <button type="submit" class="btn btn-primary btn-full">
                Book Now
              </button>
            </form>
            
            <p class="booking-note">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M8 1L10.163 5.279L15 5.635L11.5 8.794L12.326 13.636L8 11.279L3.674 13.636L4.5 8.794L1 5.635L5.837 5.279L8 1Z" fill="#F59E0B"/>
              </svg>
              Rated {experience.rating} • {experience.reviews} reviews
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .experience-hero {
    position: relative;
    height: 400px;
    display: flex;
    align-items: flex-end;
  }
  
  .hero-image {
    position: absolute;
    inset: 0;
  }
  
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);
  }
  
  .hero-content {
    position: relative;
    color: var(--color-white);
    padding-bottom: var(--spacing-2xl);
    width: 100%;
  }
  
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    font-size: 0.9375rem;
    color: var(--color-white);
    opacity: 0.9;
    margin-bottom: var(--spacing-md);
    transition: opacity 0.2s;
  }
  
  .back-link:hover {
    opacity: 1;
  }
  
  .category-tag {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    background: var(--color-primary);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    margin-bottom: var(--spacing-md);
  }
  
  .experience-title {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: var(--spacing-sm);
  }
  
  .experience-subtitle {
    font-size: 1.0625rem;
    opacity: 0.9;
    max-width: 600px;
    margin-bottom: var(--spacing-lg);
  }
  
  .experience-meta {
    display: flex;
    gap: var(--spacing-xl);
  }
  
  .meta-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: 0.9375rem;
  }
  
  .experience-content {
    padding: var(--spacing-3xl) 0;
  }
  
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: var(--spacing-2xl);
    align-items: start;
  }
  
  .section-block {
    margin-bottom: var(--spacing-2xl);
  }
  
  .section-block h2 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-black);
    margin-bottom: var(--spacing-md);
    padding-bottom: var(--spacing-sm);
    border-bottom: 2px solid var(--color-gray-200);
  }
  
  .highlights-list,
  .includes-list {
    display: grid;
    gap: var(--spacing-sm);
  }
  
  .highlights-list li,
  .includes-list li {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: 0.9375rem;
    color: var(--color-gray-700);
  }
  
  .schedule-timeline {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }
  
  .schedule-item {
    display: flex;
    gap: var(--spacing-lg);
  }
  
  .schedule-time {
    font-weight: 600;
    color: var(--color-primary);
    min-width: 60px;
  }
  
  .schedule-activity {
    color: var(--color-gray-700);
  }
  
  .info-cards {
    display: grid;
    gap: var(--spacing-md);
  }
  
  .info-card {
    background: var(--color-gray-50);
    padding: var(--spacing-lg);
    border-radius: var(--radius-md);
  }
  
  .info-card h3 {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-black);
    margin-bottom: var(--spacing-sm);
  }
  
  .info-card p,
  .info-card li {
    font-size: 0.9375rem;
    color: var(--color-gray-700);
  }
  
  .info-card ul {
    list-style: disc;
    padding-left: var(--spacing-lg);
  }
  
  .booking-sidebar {
    position: sticky;
    top: calc(var(--header-height) + var(--spacing-lg));
  }
  
  .booking-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    box-shadow: var(--shadow-lg);
  }
  
  .price-display {
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--color-gray-200);
  }
  
  .price-amount {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-black);
  }
  
  .price-label {
    font-size: 0.9375rem;
    color: var(--color-gray-500);
  }
  
  .booking-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }
  
  .form-group label {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-gray-700);
    margin-bottom: var(--spacing-xs);
  }
  
  .form-input,
  .form-select {
    width: 100%;
    padding: var(--spacing-md);
    font-size: 0.9375rem;
    border: 1px solid var(--color-gray-300);
    border-radius: var(--radius-md);
    background: var(--color-white);
  }
  
  .form-input:focus,
  .form-select:focus {
    outline: none;
    border-color: var(--color-primary);
  }
  
  .btn-full {
    width: 100%;
  }
  
  .booking-note {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    margin-top: var(--spacing-md);
    font-size: 0.8125rem;
    color: var(--color-gray-500);
    justify-content: center;
  }
  
  @media (max-width: 1024px) {
    .content-grid {
      grid-template-columns: 1fr;
    }
    
    .booking-sidebar {
      position: static;
    }
  }
  
  @media (max-width: 768px) {
    .experience-hero {
      height: 300px;
    }
    
    .experience-title {
      font-size: 1.75rem;
    }
  }
</style>