---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Booking Confirmed - MATCHS"
  description="Your booking has been confirmed. Check your email for details."
>
  <section class="confirm-hero">
    <div class="container confirm-content">
      <div class="confirm-icon">
        <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
      </div>
      <h1 class="confirm-title">Booking Confirmed!</h1>
      <p class="confirm-subtitle">Your payment was successful. We've sent the details to your email.</p>
      
      <div class="confirm-details" id="confirmDetails">
        <div class="spinner"></div>
        <p id="loadingText">Loading your booking details...</p>
      </div>

      <div class="confirm-actions">
        <a href="/" class="btn btn-primary btn-lg">Back to Home</a>
        <a href="/experiences" class="btn btn-outline btn-lg">Browse More Experiences</a>
      </div>

      <div class="support-box">
        <h3>Need help?</h3>
        <p>Contact us via <strong>WhatsApp</strong> or <strong>hello@matchses.com</strong></p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Parse session_id from URL
  const params = new URLSearchParams(window.location.search);
  const sessionId = params.get('session_id');

  if (sessionId) {
    fetch(`/api/booking.php?session_id=${encodeURIComponent(sessionId)}`)
      .then(res => res.json())
      .then(data => {
        const b = data.booking;
        document.getElementById('confirmDetails')!.innerHTML = `
          <div class="detail-card">
            <div class="detail-row"><span class="detail-label">Experience</span><span class="detail-value">${b.experience.title}</span></div>
            <div class="detail-row"><span class="detail-label">Date</span><span class="detail-value">${b.booking_date}</span></div>
            <div class="detail-row"><span class="detail-label">Guests</span><span class="detail-value">${b.guest_count} person(s)</span></div>
            <div class="detail-row"><span class="detail-label">Name</span><span class="detail-value">${b.guest_name}</span></div>
            <div class="detail-row"><span class="detail-label">Email</span><span class="detail-value">${b.guest_email}</span></div>
            <div class="detail-row"><span class="detail-label">Total</span><span class="detail-value total-highlight">¥${b.total_amount.toLocaleString()}</span></div>
            <div class="detail-row"><span class="detail-label">Status</span><span class="detail-value status-confirmed">✓ ${b.status}</span></div>
          </div>
        `;
      })
      .catch(() => {
        document.getElementById('confirmDetails')!.innerHTML = `
          <div class="detail-card">
            <p class="detail-text">Your booking has been received. You'll receive a confirmation email shortly.</p>
            <p class="detail-text">Reference: ${sessionId}</p>
          </div>
        `;
      });
  } else {
    document.getElementById('confirmDetails')!.innerHTML = `
      <div class="detail-card">
        <p class="detail-text">Your booking has been confirmed. Check your email for details.</p>
      </div>
    `;
  }
</script>

<style>
  .confirm-hero {
    background: linear-gradient(135deg, #F0FDF4 0%, #ECFEFF 100%);
    min-height: calc(100vh - var(--header-height) - 300px);
    display: flex;
    align-items: center;
    padding: var(--spacing-3xl) 0;
  }

  .confirm-content {
    text-align: center;
    max-width: 550px;
    margin: 0 auto;
  }

  .confirm-icon {
    margin-bottom: var(--spacing-xl);
    animation: scaleIn 0.5s ease;
  }
  @keyframes scaleIn {
    from { transform: scale(0); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  .confirm-title {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-primary-dark);
    margin-bottom: var(--spacing-md);
  }

  .confirm-subtitle {
    font-size: 1.125rem;
    color: var(--color-gray-700);
    margin-bottom: var(--spacing-2xl);
  }

  .confirm-details {
    margin-bottom: var(--spacing-2xl);
  }

  .detail-card {
    background: var(--color-white);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    box-shadow: var(--shadow-md);
    text-align: left;
  }

  .detail-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--spacing-sm) 0;
    border-bottom: 1px solid var(--color-gray-100);
  }
  .detail-row:last-child { border-bottom: none; }

  .detail-label {
    font-weight: 600;
    color: var(--color-gray-500);
    font-size: 0.9375rem;
  }
  .detail-value {
    font-weight: 600;
    color: var(--color-black);
  }
  .total-highlight {
    font-size: 1.25rem;
    color: var(--color-primary);
  }
  .status-confirmed {
    color: var(--color-primary);
    text-transform: capitalize;
  }

  .detail-text {
    color: var(--color-gray-700);
    padding: var(--spacing-sm) 0;
  }

  .confirm-actions {
    display: flex;
    gap: var(--spacing-md);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--spacing-2xl);
  }

  .support-box {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    margin-top: var(--spacing-lg);
  }
  .support-box h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
  }
  .support-box p {
    font-size: 0.9375rem;
    color: var(--color-gray-700);
  }

  .spinner {
    width: 32px;
    height: 32px;
    border: 3px solid var(--color-gray-200);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto var(--spacing-md);
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  @media (max-width: 768px) {
    .confirm-title { font-size: 1.75rem; }
    .confirm-actions { flex-direction: column; }
  }
</style>
