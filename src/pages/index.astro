---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import FeaturedExperiences from '../components/home/FeaturedExperiences.astro';
import ExpertCurated from '../components/home/ExpertCurated.astro';
import HowItWorks from '../components/home/HowItWorks.astro';
import TrustSection from '../components/home/TrustSection.astro';
---

<BaseLayout title="MATCHS - Local Experiences in Tokyo Tama">
  <Hero />
  <FeaturedExperiences />
  <ExpertCurated />
  <HowItWorks />
  <TrustSection />
  
  <section class="quiz-cta-section section">
    <div class="container">
      <div class="quiz-cta-content">
        <span class="quiz-tag">New</span>
        <h2 class="quiz-title">Not Sure Where to Start?</h2>
        <p class="quiz-subtitle">Take our 3-question quiz and find your perfect match in under 1 minute.</p>
        <a href="/quiz" class="btn btn-secondary btn-lg">
          Take the Quiz
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-8.707l-3-3a1 1 0 00-1.414 1.414L11.586 10H4a1 1 0 100 2h7.586l-1.293 1.293a1 1 0 101.414 1.414l3-3a1 1 0 000-1.414z" fill="currentColor"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
  
  <section class="cta-section section">
    <div class="container">
      <div class="cta-content">
        <h2 class="cta-title">Ready for Your Adventure?</h2>
        <p class="cta-subtitle">Join thousands of travelers who've discovered the hidden gems of Tokyo Tama.</p>
        <div class="cta-actions">
          <a href="/experiences" class="btn btn-primary btn-lg">
            Book Your Experience
          </a>
          <a href="/contact" class="btn btn-outline btn-lg">
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .cta-section {
    background: linear-gradient(135deg, var(--color-black) 0%, var(--color-gray-900) 100%);
    color: var(--color-white);
  }
  
  .cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .cta-title {
    font-size: 2.25rem;
    font-weight: 700;
    margin-bottom: var(--spacing-md);
  }
  
  .cta-subtitle {
    font-size: 1.0625rem;
    color: var(--color-gray-300);
    margin-bottom: var(--spacing-xl);
  }
  
  .cta-actions {
    display: flex;
    gap: var(--spacing-md);
    justify-content: center;
    flex-wrap: wrap;
  }
  
  .cta-section :global(.btn-outline) {
    border-color: var(--color-gray-500);
    color: var(--color-white);
  }
  
  .cta-section :global(.btn-outline:hover) {
    background: var(--color-white);
    color: var(--color-black);
  }

  .quiz-cta-section {
    background: var(--color-primary-light);
    border-top: 1px solid var(--color-primary);
    border-bottom: 1px solid var(--color-primary);
  }

  .quiz-cta-content {
    text-align: center;
    max-width: 500px;
    margin: 0 auto;
  }

  .quiz-tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-white);
    background: var(--color-secondary);
    padding: 2px 8px;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-md);
  }

  .quiz-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-black);
    margin-bottom: var(--spacing-sm);
  }

  .quiz-subtitle {
    font-size: 1rem;
    color: var(--color-gray-700);
    margin-bottom: var(--spacing-lg);
  }

  .quiz-cta-content :global(.btn-secondary) {
    background: var(--color-primary);
    color: var(--color-white);
  }

  .quiz-cta-content :global(.btn-secondary:hover) {
    background: var(--color-primary-dark);
  }
</style>