---
interface Props {
  title: string;
  description: string;
  price: number;
  duration: string;
  rating: number;
  reviews: number;
  image: string;
  href: string;
  highlights?: string[];
}

const { title, description, price, duration, rating, reviews, image, href, highlights = [] } = Astro.props;
---

<article class="experience-card">
  <a href={href} class="card-link">
    <div class="card-image-wrapper">
      <div class="card-image" style={`background: ${image}`}>
        <span class="card-duration">{duration}</span>
      </div>
    </div>
    
    <div class="card-content">
      <div class="card-rating">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M8 1L10.163 5.279L15 5.635L11.5 8.794L12.326 13.636L8 11.279L3.674 13.636L4.5 8.794L1 5.635L5.837 5.279L8 1Z" fill="#F59E0B"/>
        </svg>
        <span class="rating-value">{rating}</span>
        <span class="reviews-count">({reviews})</span>
      </div>
      
      <h3 class="card-title">{title}</h3>
      
      <p class="card-description">{description}</p>
      
      {highlights.length > 0 && (
        <div class="card-highlights">
          {highlights.slice(0, 3).map(highlight => (
            <span class="highlight-tag">{highlight}</span>
          ))}
        </div>
      )}
      
      <div class="card-footer">
        <div class="price">
          <span class="price-amount">${price}</span>
          <span class="price-label">/ person</span>
        </div>
        <span class="btn-book">Book Now</span>
      </div>
    </div>
  </a>
</article>

<style>
  .experience-card {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: all 0.3s ease;
  }
  
  .experience-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl);
  }
  
  .card-link {
    display: block;
  }
  
  .card-image-wrapper {
    position: relative;
    overflow: hidden;
  }
  
  .card-image {
    height: 200px;
    position: relative;
  }
  
  .card-duration {
    position: absolute;
    bottom: var(--spacing-md);
    left: var(--spacing-md);
    background: var(--color-white);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-gray-700);
  }
  
  .card-content {
    padding: var(--spacing-lg);
  }
  
  .card-rating {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-sm);
  }
  
  .rating-value {
    font-weight: 600;
    color: var(--color-gray-900);
  }
  
  .reviews-count {
    font-size: 0.875rem;
    color: var(--color-gray-500);
  }
  
  .card-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-black);
    margin-bottom: var(--spacing-sm);
    line-height: 1.3;
  }
  
  .card-description {
    font-size: 0.9375rem;
    color: var(--color-gray-700);
    margin-bottom: var(--spacing-md);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .card-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-md);
  }
  
  .highlight-tag {
    font-size: 0.75rem;
    padding: var(--spacing-xs) var(--spacing-sm);
    background: var(--color-gray-100);
    color: var(--color-gray-700);
    border-radius: var(--radius-sm);
  }
  
  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--color-gray-200);
  }
  
  .price {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-xs);
  }
  
  .price-amount {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-black);
  }
  
  .price-label {
    font-size: 0.8125rem;
    color: var(--color-gray-500);
  }
  
  .btn-book {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
  }
</style>