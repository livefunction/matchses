---
const steps = [
  {
    number: '01',
    title: 'Take the Matching Quiz',
    description: 'Answer 3 quick questions about your travel style, interests, and preferences.'
  },
  {
    number: '02',
    title: 'Get Matched with a Host',
    description: 'Our system finds verified local hosts who perfectly match your needs.'
  },
  {
    number: '03',
    title: 'Book & Enjoy',
    description: 'Connect directly with your host and enjoy an authentic Japanese experience.'
  }
];
---

<section class="how-it-works section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Simple Process</span>
      <h2 class="section-title">How MATCHS Works</h2>
      <p class="section-subtitle">
        Find your perfect local guide in just 3 simple steps. No hassle, no guesswork.
      </p>
    </div>
    
    <div class="steps-grid">
      {steps.map((step, index) => (
        <div class="step-item">
          <div class="step-number">{step.number}</div>
          <div class="step-content">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-description">{step.description}</p>
          </div>
          {index < steps.length - 1 && (
            <div class="step-connector"></div>
          )}
        </div>
      ))}
    </div>
    
    <div class="process-features">
      <div class="feature">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <span class="feature-text">Verified Hosts</span>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
        </div>
        <span class="feature-text">Smart Matching</span>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
          </svg>
        </div>
        <span class="feature-text">Direct Communication</span>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0110 0v4"/>
          </svg>
        </div>
        <span class="feature-text">Secure Booking</span>
      </div>
    </div>
  </div>
</section>

<style>
  .how-it-works {
    background: var(--color-white);
  }
  
  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--spacing-3xl);
  }
  
  .section-tag {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-md);
  }
  
  .section-title {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-black);
    margin-bottom: var(--spacing-md);
  }
  
  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--color-gray-700);
  }
  
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-2xl);
    margin-bottom: var(--spacing-3xl);
  }
  
  .step-item {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  
  .step-number {
    font-family: var(--font-serif);
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-primary);
    opacity: 0.3;
    margin-bottom: var(--spacing-md);
  }
  
  .step-content {
    padding: 0 var(--spacing-md);
  }
  
  .step-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-black);
    margin-bottom: var(--spacing-sm);
  }
  
  .step-description {
    font-size: 0.9375rem;
    color: var(--color-gray-700);
    line-height: 1.6;
  }
  
  .step-connector {
    display: none;
  }
  
  .process-features {
    display: flex;
    justify-content: center;
    gap: var(--spacing-2xl);
    flex-wrap: wrap;
    padding: var(--spacing-xl);
    background: var(--color-gray-50);
    border-radius: var(--radius-xl);
  }
  
  .feature {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }
  
  .feature-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-white);
    border-radius: 50%;
    color: var(--color-primary);
    box-shadow: var(--shadow-sm);
  }
  
  .feature-text {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-gray-700);
  }
  
  @media (max-width: 768px) {
    .steps-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-xl);
    }
    
    .process-features {
      flex-direction: column;
      align-items: center;
      gap: var(--spacing-md);
    }
  }
</style>