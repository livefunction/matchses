---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Meet Our Hosts - MATCHS"
  description="Get to know our passionate local guides in Tokyo Tama. Each host brings unique stories, expertise, and love for their community."
>
  <section class="page-header">
    <div class="container">
      <span class="page-tag">Our Hosts</span>
      <h1 class="page-title">Meet the Locals</h1>
      <p class="page-subtitle">
        Every experience is led by someone who calls Tokyo Tama home. 
        Get to know the person behind your adventure before you book.
      </p>
    </div>
  </section>

  <section class="filter-section section">
    <div class="container">
      <div class="filter-bar">
        <div class="filter-group">
          <span class="filter-label">Interests:</span>
          <div class="filter-tags">
            <button class="filter-tag active" data-filter="all">All</button>
            <button class="filter-tag" data-filter="food">Food & Cuisine</button>
            <button class="filter-tag" data-filter="nature">Nature</button>
            <button class="filter-tag" data-filter="wellness">Wellness</button>
            <button class="filter-tag" data-filter="culture">Culture</button>
          </div>
        </div>
        <div class="filter-group">
          <span class="filter-label">Communication:</span>
          <div class="filter-tags">
            <button class="filter-tag energy-filter active" data-filter="all">All</button>
            <button class="filter-tag energy-filter" data-filter="talkative">Talkative</button>
            <button class="filter-tag energy-filter" data-filter="balanced">Balanced</button>
            <button class="filter-tag energy-filter" data-filter="quiet">Quiet</button>
          </div>
        </div>
        <div class="ask-guide-link">
          <a href="/ask-guide" class="btn btn-outline btn-sm">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            Not sure? Ask a guide first
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="hosts-section section">
    <div class="container">
      <div class="hosts-grid">
        <article class="host-card" data-interests="food culture history" data-energy="talkative">
          <div class="host-image">
            <div class="host-image-placeholder host-sato"></div>
          </div>
          <div class="host-content">
            <span class="host-badge">Food Expert</span>
            <h2 class="host-name">Takeshi Sato</h2>
            <p class="host-location">Takao Area</p>
            <div class="host-story">
              <p>Born in Hachioji, Takeshi spent 15 years as a sushi chef in Ginza before returning to his hometown. Now he leads food tours that showcase the soul of Tama cuisine—from mountain soba to hidden izakaya.</p>
              <p>"I want visitors to taste what I grew up eating. Real food, made by real people, with real stories."</p>
            </div>
            <div class="host-facts">
              <div class="fact">
                <span class="fact-icon">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                    <path d="M6 12v5c3 3 9 3 12 0v-5"/>
                  </svg>
                </span>
                <span>Former Sushi Chef, 15 years</span>
              </div>
              <div class="fact">
                <span class="fact-icon">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                </span>
                <span>Tama Resident, 25+ years</span>
              </div>
              <div class="fact">
                <span class="fact-icon">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                  </svg>
                </span>
                <span>Leading tours since 2019</span>
              </div>
            </div>
            <div class="host-interests">
              <h3 class="interests-label">Interests:</h3>
              <div class="interest-tags">
                <span class="tag tag-food">Food & Cuisine</span>
                <span class="tag tag-culture">Local Culture</span>
                <span class="tag tag-history">History</span>
              </div>
            </div>
            <div class="host-energy">
              <h3 class="energy-label">Communication Style:</h3>
              <div class="energy-badge badge-talkative">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
                Warm & Talkative
              </div>
              <p class="energy-desc">Happy to chat about anything - from sushi making to local life in Tama.</p>
            </div>
            <div class="host-ideal">
              <h3 class="ideal-label">Perfect for:</h3>
              <ul class="ideal-list">
                <li>Food lovers who want deep local recommendations</li>
                <li>First-time visitors seeking authentic experience</li>
                <li>Those who enjoy conversation while exploring</li>
              </ul>
            </div>
            <div class="host-experiences">
              <h3 class="experiences-label">Leads:</h3>
              <a href="/experiences/mt-takao-food-tour" class="experience-link">Mt. Takao Food Tour</a>
              <a href="/experiences/tachikawa-izakaya-night" class="experience-link">Tachikawa Izakaya Night</a>
            </div>
            <div class="host-reviews">
              <div class="review-summary">
                <span class="rating">4.9</span>
                <span class="rating-star">★</span>
                <span class="review-count">(127 reviews)</span>
              </div>
            </div>
          </div>
        </article>

        <article class="host-card" data-interests="wellness culture nature" data-energy="balanced">
          <div class="host-image">
            <div class="host-image-placeholder host-yuki"></div>
          </div>
          <div class="host-content">
            <span class="host-badge">Wellness Guide</span>
            <h2 class="host-name">Yuki Tanaka</h2>
            <p class="host-location">Onsen Specialist</p>
            <div class="host-story">
              <p>After 10 years in Tokyo's corporate world, Yuki discovered the healing power of Tama's hot springs. Now she helps visitors unwind and reconnect with nature—something she wishes someone had shown her years ago.</p>
              <p>"In a world that never stops, I help people remember how to breathe."</p>
            </div>
            <div class="host-facts">
              <div class="fact">
                <span class="fact-icon">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                    <path d="M6 12v5c3 3 9 3 12 0v-5"/>
                  </svg>
                </span>
                <span>Former Corporate Executive</span>
              </div>
              <div class="fact">
                <span class="fact-icon">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                </span>
                <span>Tama Resident, 8 years</span>
              </div>
              <div class="fact">
                <span class="fact-icon">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                  </svg>
                </span>
                <span>Leading tours since 2021</span>
              </div>
            </div>
            <div class="host-interests">
              <h3 class="interests-label">Interests:</h3>
              <div class="interest-tags">
                <span class="tag tag-wellness">Wellness</span>
                <span class="tag tag-culture">Local Culture</span>
                <span class="tag tag-nature">Nature</span>
              </div>
            </div>
            <div class="host-energy">
              <h3 class="energy-label">Communication Style:</h3>
              <div class="energy-badge badge-balanced">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 16v-4"/>
                  <path d="M12 8h.01"/>
                </svg>
                Balanced & Thoughtful
              </div>
              <p class="energy-desc">Good conversation, but respects your space and pace.</p>
            </div>
            <div class="host-ideal">
              <h3 class="ideal-label">Perfect for:</h3>
              <ul class="ideal-list">
                <li>Travelers seeking relaxation and healing</li>
                <li>Those who appreciate calm, thoughtful guidance</li>
                <li>People wanting to disconnect and recharge</li>
              </ul>
            </div>
            <div class="host-experiences">
              <h3 class="experiences-label">Leads:</h3>
              <a href="/experiences/onsen-day-trip" class="experience-link">Onsen Day Trip</a>
            </div>
            <div class="host-reviews">
              <div class="review-summary">
                <span class="rating">4.9</span>
                <span class="rating-star">★</span>
                <span class="review-count">(203 reviews)</span>
              </div>
            </div>
          </div>
        </article>

        <article class="host-card" data-interests="nature photo culture" data-energy="quiet">
          <div class="host-image">
            <div class="host-image-placeholder host-ken"></div>
          </div>
          <div class="host-content">
            <span class="host-badge">Nature Guide</span>
            <h2 class="host-name">Kenji Watanabe</h2>
            <p class="host-location">Forest Expert</p>
            <div class="host-story">
              <p>A lifelong naturalist, Kenji has spent decades exploring Tama's forests. He can identify over 200 plant species and knows exactly where to spot wildlife. His tours are part nature walk, part living encyclopedia.</p>
              <p>"The forest has its own language. Once you learn to listen, you'll never see nature the same way."</p>
            </div>
            <div class="host-facts">
              <div class="fact">
                <span class="fact-icon">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                    <path d="M6 12v5c3 3 9 3 12 0v-5"/>
                  </svg>
                </span>
                <span>Licensed Naturalist Guide</span>
              </div>
              <div class="fact">
                <span class="fact-icon">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                </span>
                <span>Born in Hachioji, 40+ years</span>
              </div>
              <div class="fact">
                <span class="fact-icon">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                  </svg>
                </span>
                <span>Leading tours since 2018</span>
              </div>
            </div>
            <div class="host-interests">
              <h3 class="interests-label">Interests:</h3>
              <div class="interest-tags">
                <span class="tag tag-nature">Nature</span>
                <span class="tag tag-photo">Photography</span>
                <span class="tag tag-culture">Forest Culture</span>
              </div>
            </div>
            <div class="host-energy">
              <h3 class="energy-label">Communication Style:</h3>
              <div class="energy-badge badge-quiet">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
                  <path d="M12 16a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"/>
                  <path d="M12 8v2"/>
                  <path d="M12 16v.01"/>
                </svg>
                Quiet & Observant
              </div>
              <p class="energy-desc">Prefers to let nature speak. Shares knowledge when asked.</p>
            </div>
            <div class="host-ideal">
              <h3 class="ideal-label">Perfect for:</h3>
              <ul class="ideal-list">
                <li>Nature photographers seeking hidden spots</li>
                <li>Those who enjoy peaceful, reflective walks</li>
                <li>People interested in plants and wildlife</li>
              </ul>
            </div>
            <div class="host-experiences">
              <h3 class="experiences-label">Leads:</h3>
              <a href="#" class="experience-link">Tama Forest Nature Walk</a>
            </div>
            <div class="host-reviews">
              <div class="review-summary">
                <span class="rating">4.7</span>
                <span class="rating-star">★</span>
                <span class="review-count">(64 reviews)</span>
              </div>
            </div>
          </div>
        </article>
      </div>

      <div class="hosts-cta">
        <h2>Want to become a host?</h2>
        <p>Share your passion with travelers from around the world. Join our community of local experts.</p>
        <a href="/for-business" class="btn btn-primary btn-lg">Become a Host</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, #FEFCE8 0%, #F0FDF4 50%, #F0F9FF 100%);
    padding: var(--spacing-3xl) 0 var(--spacing-2xl);
    text-align: center;
  }

  .page-tag {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-md);
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-black);
    margin-bottom: var(--spacing-md);
  }

  .page-subtitle {
    font-size: 1.125rem;
    color: var(--color-gray-700);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .hosts-section {
    padding-top: var(--spacing-xl);
  }

  .filter-section {
    background: var(--color-gray-50);
    padding: var(--spacing-lg) 0;
    border-bottom: 1px solid var(--color-gray-200);
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xl);
    align-items: center;
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .filter-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-gray-700);
  }

  .filter-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
  }

  .filter-tag {
    font-size: 0.8125rem;
    font-weight: 500;
    padding: var(--spacing-xs) var(--spacing-md);
    border: 1px solid var(--color-gray-300);
    border-radius: var(--radius-full);
    background: var(--color-white);
    color: var(--color-gray-700);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-tag:hover,
  .filter-tag.active {
    background: var(--color-primary);
    color: var(--color-white);
    border-color: var(--color-primary);
  }

  .host-card.hidden {
    display: none;
  }

  .ask-guide-link {
    display: flex;
    justify-content: center;
    margin-top: var(--spacing-lg);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: var(--spacing-sm) var(--spacing-lg);
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-full);
    background: var(--color-white);
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-outline:hover {
    background: var(--color-primary);
    color: var(--color-white);
  }

  .btn-sm {
    padding: var(--spacing-xs) var(--spacing-md);
    font-size: 0.8125rem;
  }

  .hosts-grid {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2xl);
  }

  .host-card {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: var(--spacing-2xl);
    background: var(--color-white);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .host-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl);
  }

  .host-image {
    position: relative;
  }

  .host-image-placeholder {
    width: 100%;
    height: 100%;
    min-height: 350px;
  }

  .host-image-placeholder.host-sato {
    background: linear-gradient(135deg, #84CC16 0%, #65A30D 100%);
  }

  .host-image-placeholder.host-yuki {
    background: linear-gradient(135deg, #22D3EE 0%, #06B6D4 100%);
  }

  .host-image-placeholder.host-ken {
    background: linear-gradient(135deg, #22C55E 0%, #16A34A 100%);
  }

  .host-content {
    padding: var(--spacing-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .host-badge {
    display: inline-block;
    padding: var(--spacing-xs) var(--spacing-md);
    background: var(--color-primary-light);
    color: var(--color-primary-dark);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-full);
    width: fit-content;
  }

  .host-name {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-black);
    margin: 0;
  }

  .host-location {
    font-size: 0.9375rem;
    color: var(--color-gray-500);
    margin: 0;
  }

  .host-story {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .host-story p {
    font-size: 0.9375rem;
    color: var(--color-gray-700);
    line-height: 1.7;
    margin: 0;
  }

  .host-story p:last-child {
    font-style: italic;
    color: var(--color-primary-dark);
    border-left: 3px solid var(--color-primary);
    padding-left: var(--spacing-md);
  }

  .host-facts {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-md);
    padding: var(--spacing-md) 0;
    border-top: 1px solid var(--color-gray-100);
    border-bottom: 1px solid var(--color-gray-100);
  }

  .host-interests {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) 0;
  }

  .interests-label,
  .energy-label,
  .ideal-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-gray-700);
    margin: 0;
  }

  .interest-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-full);
    background: var(--color-gray-100);
    color: var(--color-gray-700);
  }

  .tag-food {
    background: #FEF3C7;
    color: #92400E;
  }

  .tag-culture {
    background: #DBEAFE;
    color: #1E40AF;
  }

  .tag-history {
    background: #FCE7F3;
    color: #9D174D;
  }

  .tag-photo {
    background: #E0E7FF;
    color: #3730A3;
  }

  .tag-anime {
    background: #F3E8FF;
    color: #6B21A8;
  }

  .tag-arch {
    background: #D1FAE5;
    color: #065F46;
  }

  .host-energy {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) 0;
  }

  .energy-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    font-size: 0.75rem;
    font-weight: 600;
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-full);
  }

  .badge-talkative {
    background: #FEF3C7;
    color: #92400E;
  }

  .badge-balanced {
    background: #E0E7FF;
    color: #3730A3;
  }

  .badge-quiet {
    background: #D1FAE5;
    color: #065F46;
  }

  .energy-desc {
    font-size: 0.8125rem;
    color: var(--color-gray-600);
    margin: 0;
    width: 100%;
  }

  .host-ideal {
    padding: var(--spacing-sm) 0;
  }

  .ideal-list {
    margin: var(--spacing-xs) 0 0;
    padding-left: var(--spacing-lg);
    font-size: 0.8125rem;
    color: var(--color-gray-600);
  }

  .ideal-list li {
    margin-bottom: var(--spacing-xs);
  }

  .fact {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    font-size: 0.875rem;
    color: var(--color-gray-600);
  }

  .fact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--color-gray-50);
    border-radius: var(--radius-full);
    color: var(--color-primary);
  }

  .host-experiences {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .experiences-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-gray-700);
    margin: 0;
  }

  .experience-link {
    font-size: 0.875rem;
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
    padding: var(--spacing-xs) var(--spacing-md);
    background: var(--color-primary-light);
    border-radius: var(--radius-full);
    transition: all 0.2s ease;
  }

  .experience-link:hover {
    background: var(--color-primary);
    color: var(--color-white);
  }

  .host-reviews {
    margin-top: auto;
  }

  .review-summary {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
  }

  .rating {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-black);
  }

  .rating-star {
    color: var(--color-accent);
    font-size: 1rem;
  }

  .review-count {
    font-size: 0.875rem;
    color: var(--color-gray-500);
  }

  .hosts-cta {
    text-align: center;
    padding: var(--spacing-3xl);
    background: var(--color-gray-50);
    border-radius: var(--radius-xl);
    margin-top: var(--spacing-3xl);
  }

  .hosts-cta h2 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-black);
    margin-bottom: var(--spacing-md);
  }

  .hosts-cta p {
    font-size: 1rem;
    color: var(--color-gray-700);
    margin-bottom: var(--spacing-xl);
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 768px) {
    .host-card {
      grid-template-columns: 1fr;
    }

    .host-image-placeholder {
      min-height: 200px;
    }

    .page-title {
      font-size: 2rem;
    }
    
    .filter-bar {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<script>
  document.querySelectorAll('.filter-tag').forEach(btn => {
    btn.addEventListener('click', () => {
      const filterType = btn.classList.contains('energy-filter') ? 'energy' : 'interests';
      const value = btn.dataset.filter;
      
      document.querySelectorAll(`.filter-tag[data-filter]`).forEach(b => {
        if (b.classList.contains('energy-filter') === (filterType === 'energy')) {
          b.classList.remove('active');
        }
      });
      btn.classList.add('active');
      
      const cards = document.querySelectorAll('.host-card');
      cards.forEach(card => {
        const cardInterests = card.getAttribute('data-interests') || '';
        const cardEnergy = card.getAttribute('data-energy') || '';
        const activeInterest = document.querySelector('.filter-tag[data-filter].active')?.dataset.filter || 'all';
        const activeEnergy = document.querySelector('.energy-filter.active')?.dataset.filter || 'all';
        
        const matchInterest = activeInterest === 'all' || cardInterests.includes(activeInterest);
        const matchEnergy = activeEnergy === 'all' || cardEnergy === activeEnergy;
        
        if (matchInterest && matchEnergy) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>