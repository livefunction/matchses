---
const steps = [
  {
    number: '01',
    title: 'Find Your Experience',
    description: 'Browse our curated selection of local tours and activities in Tokyo Tama region.'
  },
  {
    number: '02',
    title: 'Book Instantly',
    description: 'Select your date, number of guests, and book securely with Stripe. No account needed.'
  },
  {
    number: '03',
    title: 'Enjoy!',
    description: 'Meet your local guide and enjoy an authentic Japanese experience. Memories guaranteed.'
  }
];
---

<section class="how-it-works section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Simple Process</span>
      <h2 class="section-title">How It Works</h2>
      <p class="section-subtitle">
        Book your perfect experience in just 3 simple steps. No hidden fees, no hassle.
      </p>
    </div>
    
    <div class="steps-grid">
      {steps.map((step, index) => (
        <div class="step-item">
          <div class="step-number">{step.number}</div>
          <div class="step-content">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-description">{step.description}</p>
          </div>
          {index < steps.length - 1 && (
            <div class="step-connector"></div>
          )}
        </div>
      ))}
    </div>
    
    <div class="process-features">
      <div class="feature">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <span class="feature-text">Secure Booking</span>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <span class="feature-text">Instant Confirmation</span>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
          </svg>
        </div>
        <span class="feature-text">24/7 Support</span>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="1" x2="12" y2="23"/>
            <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
          </svg>
        </div>
        <span class="feature-text">Best Price Guarantee</span>
      </div>
    </div>
  </div>
</section>

<style>
  .how-it-works {
    background: var(--color-white);
  }
  
  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--spacing-3xl);
  }
  
  .section-tag {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-md);
  }
  
  .section-title {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-black);
    margin-bottom: var(--spacing-md);
  }
  
  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--color-gray-700);
  }
  
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-2xl);
    margin-bottom: var(--spacing-3xl);
  }
  
  .step-item {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  
  .step-number {
    font-family: var(--font-serif);
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-primary);
    opacity: 0.3;
    margin-bottom: var(--spacing-md);
  }
  
  .step-content {
    padding: 0 var(--spacing-md);
  }
  
  .step-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-black);
    margin-bottom: var(--spacing-sm);
  }
  
  .step-description {
    font-size: 0.9375rem;
    color: var(--color-gray-700);
    line-height: 1.6;
  }
  
  .step-connector {
    display: none;
  }
  
  .process-features {
    display: flex;
    justify-content: center;
    gap: var(--spacing-2xl);
    flex-wrap: wrap;
    padding: var(--spacing-xl);
    background: var(--color-gray-50);
    border-radius: var(--radius-xl);
  }
  
  .feature {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }
  
  .feature-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-white);
    border-radius: 50%;
    color: var(--color-primary);
    box-shadow: var(--shadow-sm);
  }
  
  .feature-text {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-gray-700);
  }
  
  @media (max-width: 768px) {
    .steps-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-xl);
    }
    
    .process-features {
      flex-direction: column;
      align-items: center;
      gap: var(--spacing-md);
    }
  }
</style>