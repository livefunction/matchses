---
const trustItems = [
  {
    icon: 'local',
    title: 'Local Experts',
    description: 'All tours are led by verified local guides with deep knowledge of the area.'
  },
  {
    icon: 'price',
    title: 'Best Price Guarantee',
    description: 'Found a lower price? We\'ll match it. No hidden fees or surprise charges.'
  },
  {
    icon: 'confirm',
    title: 'Instant Confirmation',
    description: 'Book now and get immediate confirmation. Your spot is guaranteed.'
  },
  {
    icon: 'support',
    title: '24/7 Support',
    description: 'English-speaking support team available anytime to help you.'
  },
  {
    icon: 'refund',
    title: 'Free Cancellation',
    description: 'Cancel up to 24 hours before for a full refund. No questions asked.'
  },
  {
    icon: 'secure',
    title: 'Secure Payments',
    description: 'Your payment is protected with Stripe\'s bank-level security.'
  }
];
---

<section class="trust-section section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Why Choose MATCHS</span>
      <h2 class="section-title">Travel With Confidence</h2>
      <p class="section-subtitle">
        We're committed to making your Tokyo Tama experience unforgettable.
      </p>
    </div>
    
    <div class="trust-grid">
      {trustItems.map(item => (
        <div class="trust-item">
          <div class="trust-icon">
            {item.icon === 'local' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            )}
            {item.icon === 'price' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="1" x2="12" y2="23"/>
                <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
              </svg>
            )}
            {item.icon === 'confirm' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            )}
            {item.icon === 'support' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
              </svg>
            )}
            {item.icon === 'refund' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 12a9 9 0 1018 0 9 9 0 10-18 0"/>
                <path d="M3 12h4"/>
                <path d="M12 7v5l3 3"/>
              </svg>
            )}
            {item.icon === 'secure' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0110 0v4"/>
              </svg>
            )}
          </div>
          <h3 class="trust-title">{item.title}</h3>
          <p class="trust-description">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-section {
    background: var(--color-gray-50);
  }
  
  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--spacing-3xl);
  }
  
  .section-tag {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-md);
  }
  
  .section-title {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-black);
    margin-bottom: var(--spacing-md);
  }
  
  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--color-gray-700);
  }
  
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
  }
  
  .trust-item {
    background: var(--color-white);
    padding: var(--spacing-xl);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    transition: all 0.3s ease;
  }
  
  .trust-item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  
  .trust-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    border-radius: var(--radius-md);
    color: var(--color-white);
    margin-bottom: var(--spacing-md);
  }
  
  .trust-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-black);
    margin-bottom: var(--spacing-sm);
  }
  
  .trust-description {
    font-size: 0.9375rem;
    color: var(--color-gray-700);
    line-height: 1.5;
  }
  
  @media (max-width: 1024px) {
    .trust-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 640px) {
    .trust-grid {
      grid-template-columns: 1fr;
    }
  }
</style>