---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Sign Up - MATCHS"
  description="Create your MATCHS account. Sign up as a traveler to book experiences or as a guide to share your local expertise."
>
  <section class="auth-hero">
    <div class="container">
      <div class="auth-tabs">
        <button class="auth-tab active" data-tab="traveler">I'm a Traveler</button>
        <button class="auth-tab" data-tab="guide">I'm a Guide</button>
      </div>
    </div>
  </section>

  <section class="auth-section section">
    <div class="container">
      <div class="auth-container">
        <div class="auth-card">
          <div class="auth-header">
            <h1 class="auth-title">Create Account</h1>
            <p class="auth-subtitle" id="authSubtitle">Join MATCHS to discover local experiences</p>
          </div>

          <form class="auth-form" id="registerForm">
            <div class="form-group" id="nameGroup">
              <label for="name">Full Name</label>
              <input type="text" id="name" name="name" class="form-input" required placeholder="Your full name" />
            </div>

            <div class="form-group" id="businessNameGroup" style="display: none;">
              <label for="businessName">Business Name</label>
              <input type="text" id="businessName" name="businessName" class="form-input" placeholder="Your guiding business name" />
            </div>
            
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" class="form-input" required placeholder="your@email.com" />
            </div>

            <div class="form-group">
              <label for="password">Password</label>
              <input type="password" id="password" name="password" class="form-input" required placeholder="Create a password (8+ characters)" />
            </div>

            <div class="form-group" id="experienceGroup" style="display: none;">
              <label for="experience">Years of Guiding Experience</label>
              <select id="experience" name="experience" class="form-select">
                <option value="">Select...</option>
                <option value="0-1">Less than 1 year</option>
                <option value="1-3">1-3 years</option>
                <option value="3-5">3-5 years</option>
                <option value="5+">More than 5 years</option>
              </select>
            </div>

            <div class="form-group" id="areaGroup" style="display: none;">
              <label for="area">Primary Area</label>
              <select id="area" name="area" class="form-select">
                <option value="">Select area...</option>
                <option value="takao">Mt. Takao Area</option>
                <option value="tachikawa">Tachikawa</option>
                <option value="hachioji">Hachioji</option>
                <option value="machida">Machida</option>
              </select>
            </div>
            
            <div class="form-options">
              <label class="checkbox-label">
                <input type="checkbox" name="terms" required />
                <span>I agree to the <a href="/terms">Terms of Service</a></span>
              </label>
            </div>
            
            <button type="submit" class="btn btn-primary btn-full">
              Create Account
            </button>
          </form>

          <p class="auth-footer">
            Already have an account? <a href="/login">Login</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .auth-hero {
    background: var(--color-gray-50);
    padding: var(--spacing-xl) 0;
    border-bottom: 1px solid var(--color-gray-200);
  }

  .auth-tabs {
    display: flex;
    justify-content: center;
    gap: var(--spacing-sm);
  }

  .auth-tab {
    padding: var(--spacing-sm) var(--spacing-xl);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-gray-600);
    background: transparent;
    border: 2px solid var(--color-gray-200);
    border-radius: var(--radius-full);
    cursor: pointer;
    transition: all 0.2s;
  }

  .auth-tab:hover {
    border-color: var(--color-gray-300);
  }

  .auth-tab.active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-white);
  }

  .auth-section {
    padding-top: var(--spacing-2xl);
  }

  .auth-container {
    max-width: 440px;
    margin: 0 auto;
  }

  .auth-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-xl);
    padding: var(--spacing-2xl);
    box-shadow: var(--shadow-md);
  }

  .auth-header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }

  .auth-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-black);
    margin-bottom: var(--spacing-sm);
  }

  .auth-subtitle {
    font-size: 0.9375rem;
    color: var(--color-gray-600);
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .form-group label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-gray-700);
  }

  .form-input,
  .form-select {
    width: 100%;
    padding: var(--spacing-md);
    font-size: 0.9375rem;
    border: 1px solid var(--color-gray-300);
    border-radius: var(--radius-md);
    background: var(--color-white);
    transition: border-color 0.2s;
  }

  .form-input:focus,
  .form-select:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .form-options {
    display: flex;
    align-items: center;
    font-size: 0.875rem;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    cursor: pointer;
    color: var(--color-gray-700);
  }

  .checkbox-label input {
    width: 16px;
    height: 16px;
  }

  .checkbox-label a {
    color: var(--color-primary);
  }

  .btn-full {
    width: 100%;
    justify-content: center;
  }

  .auth-footer {
    text-align: center;
    font-size: 0.9375rem;
    color: var(--color-gray-600);
    margin-top: var(--spacing-lg);
  }

  .auth-footer a {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
  }

  @media (max-width: 480px) {
    .auth-tabs {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll('.auth-tab');
  const subtitle = document.getElementById('authSubtitle');
  const title = document.querySelector('.auth-title');
  const nameGroup = document.getElementById('nameGroup');
  const businessNameGroup = document.getElementById('businessNameGroup');
  const experienceGroup = document.getElementById('experienceGroup');
  const areaGroup = document.getElementById('areaGroup');
  const nameLabel = nameGroup?.querySelector('label');
  const nameInput = nameGroup?.querySelector('input');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      
      if (tab.dataset.tab === 'guide') {
        subtitle.textContent = 'Share your local expertise with travelers worldwide';
        title.textContent = 'Become a Guide';
        businessNameGroup.style.display = 'flex';
        experienceGroup.style.display = 'flex';
        areaGroup.style.display = 'flex';
        nameLabel.textContent = 'Your Name';
      } else {
        subtitle.textContent = 'Join MATCHS to discover local experiences';
        title.textContent = 'Create Account';
        businessNameGroup.style.display = 'none';
        experienceGroup.style.display = 'none';
        areaGroup.style.display = 'none';
        nameLabel.textContent = 'Full Name';
      }
    });
  });
</script>