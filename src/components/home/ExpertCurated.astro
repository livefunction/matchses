---
const hostTypes = [
  {
    id: 'food-culture',
    title: 'Food & Culture',
    description: 'Taste authentic local cuisine and learn about Japanese traditions',
    icon: 'food',
    features: [
      { name: 'Local restaurant tours', reason: 'Hidden gems only locals know' },
      { name: 'Cooking classes', reason: 'Learn to make Japanese dishes' },
    ]
  },
  {
    id: 'nature-adventure',
    title: 'Nature & Adventure',
    description: 'Explore beautiful landscapes and outdoor activities',
    icon: 'nature',
    features: [
      { name: 'Mountain hiking guides', reason: 'Scenic trails with expert guides' },
      { name: 'Seasonal experiences', reason: 'Cherry blossoms, autumn leaves' },
    ]
  },
  {
    id: 'nightlife-social',
    title: 'Nightlife & Social',
    description: 'Experience Japanese bar culture and make local friends',
    icon: 'social',
    features: [
      { name: 'Izakaya hopping', reason: 'Visit authentic local pubs' },
      { name: 'Cultural events', reason: 'Festivals and local gatherings' },
    ]
  }
];
---

<section class="curated-section section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Host Categories</span>
      <h2 class="section-title">Find Your Perfect Host Type</h2>
      <p class="section-subtitle">
        Choose from verified local hosts specializing in different experiences. We match you based on your interests.
      </p>
    </div>
    
    <div class="curated-grid">
      {hostTypes.map(type => (
        <div class="curated-card" id={type.id}>
          <div class="curated-header">
            <div class="curated-icon">
              {type.icon === 'food' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/>
                  <line x1="6" y1="1" x2="6" y2="4"/>
                  <line x1="10" y1="1" x2="10" y2="4"/>
                  <line x1="14" y1="1" x2="14" y2="4"/>
                </svg>
              )}
              {type.icon === 'nature' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66.95-2.3c.48.17.98.3 1.34.3C19 20 22 3 22 3c-1 2-8 2.25-13 3.25S2 11.5 2 13.5s1.75 3 3.75 3"/>
                </svg>
              )}
              {type.icon === 'social' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
                </svg>
              )}
            </div>
            <div class="curated-title-group">
              <h3 class="curated-title">{type.title}</h3>
              <p class="curated-description">{type.description}</p>
            </div>
          </div>
          
          <div class="curated-experiences">
            {type.features.map(feature => (
              <div class="curated-experience">
                <span class="exp-name">{feature.name}</span>
                <span class="exp-reason">{feature.reason}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
      </div>
    </div>
    
    <div class="quiz-cta">
      <p class="quiz-cta-text">Not sure which type is right for you?</p>
      <a href="/quiz" class="quiz-cta-btn">
        Take our 3-question quiz to find your perfect match
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .curated-section {
    background: var(--color-white);
  }

  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--spacing-3xl);
  }

  .section-tag {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-md);
  }

  .section-title {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-black);
    margin-bottom: var(--spacing-md);
  }

  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--color-gray-700);
  }

  .curated-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
  }

  .curated-card {
    background: var(--color-gray-50);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    transition: all 0.3s ease;
    border: 2px solid transparent;
  }

  .curated-card:hover {
    background: var(--color-white);
    border-color: var(--color-primary);
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .curated-header {
    display: flex;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
  }

  .curated-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-white);
    border-radius: var(--radius-lg);
    color: var(--color-primary);
    box-shadow: var(--shadow-sm);
    flex-shrink: 0;
  }

  .curated-title-group {
    flex: 1;
  }

  .curated-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-black);
    margin: 0 0 var(--spacing-xs);
  }

  .curated-description {
    font-size: 0.875rem;
    color: var(--color-gray-600);
    margin: 0;
    line-height: 1.5;
  }

  .curated-experiences {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .curated-experience {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-md);
    background: var(--color-white);
    border-radius: var(--radius-md);
  }

  .exp-name {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-black);
  }

  .exp-reason {
    font-size: 0.8125rem;
    color: var(--color-gray-500);
    flex: 1;
  }

  .quiz-cta {
    text-align: center;
    margin-top: var(--spacing-2xl);
    padding-top: var(--spacing-2xl);
    border-top: 1px solid var(--color-gray-200);
  }

  .quiz-cta-text {
    font-size: 0.9375rem;
    color: var(--color-gray-600);
    margin-bottom: var(--spacing-md);
  }

  .quiz-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .quiz-cta-btn:hover {
    color: var(--color-primary-dark);
  }

  @media (max-width: 1024px) {
    .curated-grid {
      grid-template-columns: 1fr;
      max-width: 500px;
      margin: 0 auto;
    }
  }

  @media (max-width: 640px) {
    .section-title {
      font-size: 1.75rem;
    }

    .curated-card {
      padding: var(--spacing-lg);
    }
  }
</style>